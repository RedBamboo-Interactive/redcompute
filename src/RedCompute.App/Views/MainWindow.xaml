<Window x:Class="RedCompute.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:RedCompute.App.Views.Components"
        Title="RedCompute" Width="1200" Height="800"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Border CornerRadius="12"
            Background="{DynamicResource MaterialDesignPaper}"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.4"/>
        </Border.Effect>
        <Border CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <materialDesign:PackIcon Kind="ServerNetwork" Width="18" Height="18"
                                                 Foreground="{DynamicResource AccentGreen}" Margin="0,0,8,0"/>
                        <TextBlock Text="RedCompute" FontWeight="Medium" Foreground="#72767D" FontSize="13"/>
                        <TextBlock Text=" — " Foreground="#72767D" FontSize="13" Opacity="0.7"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#72767D" FontSize="13" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                        <Button Width="40" Height="30" Click="Minimize_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#ADAEB3" Padding="0">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
                        </Button>
                        <Button Width="40" Height="30" Click="Maximize_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#ADAEB3" Padding="0">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="18" Height="18"/>
                        </Button>
                        <Button Width="40" Height="30" Click="Close_Click" Padding="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                    <Setter Property="Foreground" Value="#ADAEB3"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FF5252"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Main Content with Navigation Rail -->
                <TabControl Grid.Row="1"
                            Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                            Background="Transparent"
                            BorderThickness="0"
                            SelectedIndex="{Binding SelectedTabIndex}">

                    <!-- Dashboard -->
                    <TabItem materialDesign:RippleAssist.IsDisabled="True" Background="Transparent">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignNavigationRailTabItem}">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Border Style="{StaticResource NavRailIconContainer}">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="24" Height="24"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         ToolTip="Dashboard" Style="{StaticResource NavRailIcon}"/>
                            </Border>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Capabilities" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16"/>
                                <ItemsControl ItemsSource="{Binding CapabilityCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8"
                                                    Padding="16" Margin="0,0,16,16" Width="300">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                                            <Ellipse.Fill>
                                                                <SolidColorBrush Color="{Binding StatusColor}"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                                    </StackPanel>
                                                    <TextBlock Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4">
                                                        <Run Text="Status: "/><Run Text="{Binding Status}"/>
                                                    </TextBlock>
                                                    <TextBlock Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12">
                                                        <Run Text="Provider: "/><Run Text="{Binding ProviderName}"/>
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Start" Command="{Binding StartCommand}" Margin="0,0,8,0"
                                                                Style="{StaticResource MaterialDesignFlatButton}"/>
                                                        <Button Content="Stop" Command="{Binding StopCommand}"
                                                                Style="{StaticResource MaterialDesignFlatButton}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Jobs (Master-Detail) -->
                    <TabItem materialDesign:RippleAssist.IsDisabled="True" Background="Transparent">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignNavigationRailTabItem}">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Border Style="{StaticResource NavRailIconContainer}">
                                <materialDesign:PackIcon Kind="FormatListBulleted" Width="24" Height="24"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         ToolTip="Jobs" Style="{StaticResource NavRailIcon}"/>
                            </Border>
                        </TabItem.Header>
                        <components:JobsTabContent/>
                    </TabItem>

                    <!-- Settings -->
                    <TabItem materialDesign:RippleAssist.IsDisabled="True" Background="Transparent">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignNavigationRailTabItem}">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Border Style="{StaticResource NavRailIconContainer}">
                                <materialDesign:PackIcon Kind="CogOutline" Width="24" Height="24"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         ToolTip="Settings" Style="{StaticResource NavRailIcon}"/>
                            </Border>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                            <StackPanel MaxWidth="600">
                                <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16"/>

                                <TextBlock Text="GENERAL" FontSize="11" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="API Port" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding ApiPort, Mode=TwoWay}" Width="100" HorizontalAlignment="Left"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Job Retention (days)" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding JobRetentionDays, Mode=TwoWay}" Width="100" HorizontalAlignment="Left"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="CONFIGURATION FILE" FontSize="11" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ConfigPath}" Foreground="{DynamicResource TextMuted}" FontFamily="Consolas" FontSize="11" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Open Config File" Command="{Binding OpenConfigCommand}" Margin="0,0,8,0"
                                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                                            <Button Content="Save Changes" Command="{Binding SaveConfigCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="CAPABILITIES" FontSize="11" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding CapabilitySettings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                                        <TextBlock Text="{Binding Slug, StringFormat=  ({0})}" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Provider" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ActiveProvider}" Foreground="White" FontSize="11"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Backend Port" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding BackendPort}" Foreground="White" FontSize="11" FontFamily="Consolas"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="WSL Distro" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding WslDistro}" Foreground="White" FontSize="11"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Server Path" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ServerPath}" Foreground="White" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Model" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Model}" Foreground="White" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Health Endpoint" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding HealthEndpoint}" Foreground="White" FontSize="11" FontFamily="Consolas"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="API ENDPOINTS" FontSize="11" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4">
                                            <Run Text="GET  " Foreground="{DynamicResource AccentGreen}"/><Run Text="{Binding ApiBaseUrl, StringFormat={}{0}/discover, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4">
                                            <Run Text="GET  " Foreground="{DynamicResource AccentGreen}"/><Run Text="{Binding ApiBaseUrl, StringFormat={}{0}/openapi.json, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4">
                                            <Run Text="GET  " Foreground="{DynamicResource AccentGreen}"/><Run Text="{Binding ApiBaseUrl, StringFormat={}{0}/status, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4">
                                            <Run Text="POST " Foreground="{DynamicResource AccentOrange}"/><Run Text="{Binding ApiBaseUrl, StringFormat={}{0}/tts/generate, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Logs -->
                    <TabItem materialDesign:RippleAssist.IsDisabled="True" Background="Transparent">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignNavigationRailTabItem}">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Border Style="{StaticResource NavRailIconContainer}">
                                <materialDesign:PackIcon Kind="Console" Width="24" Height="24"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         ToolTip="Logs" Style="{StaticResource NavRailIcon}"/>
                            </Border>
                        </TabItem.Header>
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="16,16,16,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Logs" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBox Grid.Column="1" Text="{Binding LogFilter, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Filter logs..."
                                         Foreground="White" FontFamily="Consolas" FontSize="11"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="Open File" Command="{Binding OpenLogFileCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}" Margin="8,0,0,0" FontSize="11"/>
                                <Button Grid.Column="3" Content="Clear" Command="{Binding ClearLogsCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}" Margin="4,0,0,0" FontSize="11"/>
                            </Grid>
                            <ListBox x:Name="LogsList" ItemsSource="{Binding LogEntries}" Background="{DynamicResource DeepBackground}" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"/>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Border>
</Window>
