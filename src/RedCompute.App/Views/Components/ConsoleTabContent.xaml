<UserControl x:Class="RedCompute.App.Views.Components.ConsoleTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="16">
        <Border Background="#323338" CornerRadius="8" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Toolbar Row -->
                <Border Grid.Row="0" BorderBrush="#3F4147" BorderThickness="0,0,0,1" Padding="12,8">
                    <DockPanel>
                        <!-- Clear button (far right) -->
                        <Button DockPanel.Dock="Right" Command="{Binding ClearLogCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#ADAEB3" Padding="8,4" Height="30"
                                ToolTip="Clear all logs">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Clear" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <!-- Open file button -->
                        <Button DockPanel.Dock="Right" Command="{Binding DataContext.OpenLogFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#ADAEB3" Padding="8,4" Height="30"
                                ToolTip="Open log file">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentOutline" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="File" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <!-- Entry count badge -->
                        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0"
                                   Foreground="#72767D" FontSize="11">
                            <Run Text="{Binding Entries.Count, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- Search box -->
                        <Border DockPanel.Dock="Left" Background="#15FFFFFF" CornerRadius="4"
                                Padding="8,4" MaxWidth="250" VerticalAlignment="Center">
                            <DockPanel>
                                <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16"
                                                         Foreground="#72767D" DockPanel.Dock="Left"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#DCDDDE" FontSize="12" VerticalAlignment="Center"
                                         materialDesign:HintAssist.Hint="Search logs..."
                                         materialDesign:HintAssist.IsFloating="False"
                                         CaretBrush="#DCDDDE"
                                         Style="{x:Null}"/>
                            </DockPanel>
                        </Border>

                        <!-- Tag filter chips -->
                        <ItemsControl ItemsSource="{Binding AvailableTags}" Margin="8,0,0,0"
                                      VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="TagChip" CornerRadius="4" Padding="6,2" Margin="2"
                                            Cursor="Hand" Background="#15FFFFFF"
                                            MouseLeftButtonDown="TagChip_Click">
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#ADAEB3"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- Log ListView -->
                <ListView Grid.Row="1" x:Name="LogListView"
                          ItemsSource="{Binding Entries}"
                          SelectedItem="{Binding SelectedEntry}"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <!-- Expand indicator (right) -->
                                <materialDesign:PackIcon DockPanel.Dock="Right" Kind="ChevronDown"
                                                         Width="14" Height="14" Foreground="#50FFFFFF"
                                                         VerticalAlignment="Center" Margin="4,0,0,0"
                                                         Visibility="{Binding IsMultiline, Converter={StaticResource BoolToVis}}"/>

                                <!-- Timestamp -->
                                <TextBlock DockPanel.Dock="Left" Text="{Binding TimestampText}"
                                           FontFamily="Consolas" FontSize="11" Foreground="#66FFFFFF"
                                           VerticalAlignment="Center" Width="82" Margin="0,0,8,0"/>

                                <!-- Tag badge -->
                                <Border DockPanel.Dock="Left" CornerRadius="4" Padding="6,1" Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Background="{Binding TagColor, Converter={StaticResource SemiTransparentBrush}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tag}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Tag}" FontSize="10" FontWeight="Medium"
                                               Foreground="{Binding TagColor, Converter={StaticResource StringToBrush}}"/>
                                </Border>

                                <!-- Message -->
                                <TextBlock Text="{Binding PreviewMessage}" FontFamily="Consolas" FontSize="12"
                                           Foreground="#DCDDDE" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxHeight="20"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Divider -->
                <Border Grid.Row="2" Height="1" Background="#3F4147"
                        Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource BoolToVis}}"/>

                <!-- Detail Panel -->
                <Border Grid.Row="3" Background="#15FFFFFF" Padding="12,8"
                        Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource BoolToVis}}"
                        MinHeight="120" MaxHeight="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Detail header -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="#72767D" Padding="4" Width="28" Height="28"
                                    ToolTip="Close detail panel">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                            </Button>

                            <TextBlock Text="{Binding SelectedEntry.TimestampText}" FontFamily="Consolas"
                                       FontSize="11" Foreground="#66FFFFFF" VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <Border CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                                    Background="{Binding SelectedEntry.TagColor, Converter={StaticResource SemiTransparentBrush}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedEntry.Tag}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SelectedEntry.Tag}" FontSize="10" FontWeight="Medium"
                                           Foreground="{Binding SelectedEntry.TagColor, Converter={StaticResource StringToBrush}}"/>
                            </Border>
                        </DockPanel>

                        <!-- Detail content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding SelectedEntry.FullMessage, Mode=OneWay}"
                                     IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="12" Foreground="#DCDDDE"
                                     TextWrapping="Wrap" Padding="0"
                                     Style="{x:Null}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>

</UserControl>
